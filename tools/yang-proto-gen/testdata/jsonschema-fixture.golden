{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "count": {
      "maximum": 100,
      "minimum": 0,
      "type": "integer"
    },
    "detail": {
      "additionalProperties": false,
      "properties": {
        "note": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "kind": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "occurred-at": {
      "format": "date-time",
      "type": "string"
    }
  },
  "required": [
    "name"
  ],
  "type": "object"
}
