{
  "tsam-mode-changed": {
  "$defs": {
    "WireSource": {
      "additionalProperties": false,
      "properties": {
        "decoder": {
          "type": "string"
        },
        "indiana-code": {
          "maximum": 65535,
          "minimum": 0,
          "type": "integer"
        },
        "indiana-param": {
          "maximum": 255,
          "minimum": 0,
          "type": "integer"
        },
        "message-id": {
          "maximum": 65535,
          "minimum": 0,
          "type": "integer"
        },
        "oid": {
          "type": "string"
        },
        "oid-value": {
          "type": "string"
        },
        "register": {
          "type": "string"
        },
        "register-value": {
          "type": "string"
        }
      },
      "required": [
        "decoder"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "changed-at": {
      "format": "date-time",
      "type": "string"
    },
    "current": {
      "enum": [
        "active",
        "advisory",
        "disabled",
        "suspended"
      ],
      "type": "string"
    },
    "kind": {
      "type": "string"
    },
    "prior": {
      "enum": [
        "active",
        "advisory",
        "disabled",
        "suspended"
      ],
      "type": "string"
    },
    "reason": {
      "type": "string"
    },
    "source": {
      "$ref": "#/$defs/WireSource"
    },
    "source-device-id": {
      "maxLength": 64,
      "minLength": 1,
      "pattern": "^([a-zA-Z0-9_-]+)$",
      "type": "string"
    }
  },
  "required": [
    "current",
    "kind",
    "source-device-id"
  ],
  "type": "object"
},
  "tsam-recommendation-applied": {
  "$defs": {
    "WireSource": {
      "additionalProperties": false,
      "properties": {
        "decoder": {
          "type": "string"
        },
        "indiana-code": {
          "maximum": 65535,
          "minimum": 0,
          "type": "integer"
        },
        "indiana-param": {
          "maximum": 255,
          "minimum": 0,
          "type": "integer"
        },
        "message-id": {
          "maximum": 65535,
          "minimum": 0,
          "type": "integer"
        },
        "oid": {
          "type": "string"
        },
        "oid-value": {
          "type": "string"
        },
        "register": {
          "type": "string"
        },
        "register-value": {
          "type": "string"
        }
      },
      "required": [
        "decoder"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "adjustment-type": {
      "enum": [
        "cycle-length",
        "offset-adjustment",
        "other",
        "phase-extension",
        "phase-truncation",
        "plan-change",
        "split-adjustment"
      ],
      "type": "string"
    },
    "applied-at": {
      "format": "date-time",
      "type": "string"
    },
    "kind": {
      "type": "string"
    },
    "magnitude-seconds": {
      "type": "string"
    },
    "phase-number": {
      "maximum": 255,
      "minimum": 0,
      "type": "integer"
    },
    "rationale": {
      "type": "string"
    },
    "recommendation-id": {
      "type": "string"
    },
    "source": {
      "$ref": "#/$defs/WireSource"
    },
    "source-device-id": {
      "maxLength": 64,
      "minLength": 1,
      "pattern": "^([a-zA-Z0-9_-]+)$",
      "type": "string"
    }
  },
  "required": [
    "adjustment-type",
    "applied-at",
    "kind",
    "source-device-id"
  ],
  "type": "object"
}
}
