{
  "$defs": {
    "WireSource": {
      "additionalProperties": false,
      "properties": {
        "decoder": {
          "type": "string"
        },
        "indiana-code": {
          "maximum": 65535,
          "minimum": 0,
          "type": "integer"
        },
        "indiana-param": {
          "maximum": 255,
          "minimum": 0,
          "type": "integer"
        },
        "message-id": {
          "maximum": 65535,
          "minimum": 0,
          "type": "integer"
        },
        "oid": {
          "type": "string"
        },
        "oid-value": {
          "type": "string"
        },
        "register": {
          "type": "string"
        },
        "register-value": {
          "type": "string"
        }
      },
      "required": [
        "decoder"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "adjustment-seconds": {
      "type": "string"
    },
    "event": {
      "enum": [
        "adjustment-early-green",
        "adjustment-extend-green",
        "check-in",
        "check-out",
        "detector-off",
        "detector-on",
        "early-force-off",
        "service-end",
        "service-start",
        "unspecified"
      ],
      "type": "string"
    },
    "kind": {
      "type": "string"
    },
    "occurred-at": {
      "format": "date-time",
      "type": "string"
    },
    "priority-class": {
      "maximum": 4294967295,
      "minimum": 0,
      "type": "integer"
    },
    "source": {
      "$ref": "#/$defs/WireSource"
    },
    "source-device-id": {
      "maxLength": 64,
      "minLength": 1,
      "pattern": "^([a-zA-Z0-9_-]+)$",
      "type": "string"
    },
    "vehicle-id": {
      "type": "string"
    }
  },
  "required": [
    "kind",
    "occurred-at",
    "source-device-id"
  ],
  "type": "object"
}