{
  "$defs": {
    "WireSource": {
      "additionalProperties": false,
      "properties": {
        "decoder": {
          "type": "string"
        },
        "indiana-code": {
          "maximum": 65535,
          "minimum": 0,
          "type": "integer"
        },
        "indiana-param": {
          "maximum": 255,
          "minimum": 0,
          "type": "integer"
        },
        "message-id": {
          "maximum": 65535,
          "minimum": 0,
          "type": "integer"
        },
        "oid": {
          "type": "string"
        },
        "oid-value": {
          "type": "string"
        },
        "register": {
          "type": "string"
        },
        "register-value": {
          "type": "string"
        }
      },
      "required": [
        "decoder"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "call-registered": {
      "type": "boolean"
    },
    "hold-active": {
      "type": "boolean"
    },
    "kind": {
      "type": "string"
    },
    "occurred-at": {
      "format": "date-time",
      "type": "string"
    },
    "phase-number": {
      "maximum": 40,
      "minimum": 1,
      "type": "integer"
    },
    "source": {
      "$ref": "#/$defs/WireSource"
    },
    "source-device-id": {
      "maxLength": 64,
      "minLength": 1,
      "pattern": "^([a-zA-Z0-9_-]+)$",
      "type": "string"
    },
    "termination-reason": {
      "enum": [
        "force-off",
        "gap-out",
        "max-out",
        "skipped",
        "unspecified"
      ],
      "type": "string"
    },
    "to-state": {
      "enum": [
        "dark",
        "green",
        "red",
        "red-clearance",
        "unspecified",
        "yellow"
      ],
      "type": "string"
    }
  },
  "required": [
    "kind",
    "occurred-at",
    "phase-number",
    "source-device-id"
  ],
  "type": "object"
}