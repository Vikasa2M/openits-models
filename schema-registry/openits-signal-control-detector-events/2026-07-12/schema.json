{
  "detector-report": {
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "detector": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "detector-id": {
            "maximum": 65535,
            "minimum": 0,
            "type": "integer"
          },
          "occupancy": {
            "maximum": 100,
            "minimum": 0,
            "type": "integer"
          },
          "phase-served": {
            "maximum": 255,
            "minimum": 0,
            "type": "integer"
          },
          "volume": {
            "maximum": 4294967295,
            "minimum": 0,
            "type": "integer"
          }
        },
        "type": "object"
      },
      "type": "array"
    },
    "interval-duration-s": {
      "maximum": 3600,
      "minimum": 1,
      "type": "integer"
    },
    "interval-start": {
      "format": "date-time",
      "type": "string"
    },
    "occurred-at": {
      "format": "date-time",
      "type": "string"
    },
    "source-device-id": {
      "maxLength": 64,
      "minLength": 1,
      "pattern": "^([a-zA-Z0-9_-]+)$",
      "type": "string"
    }
  },
  "required": [
    "occurred-at",
    "source-device-id"
  ],
  "type": "object"
},
  "detector-transition": {
  "$defs": {
    "WireSource": {
      "additionalProperties": false,
      "properties": {
        "decoder": {
          "type": "string"
        },
        "indiana-code": {
          "maximum": 65535,
          "minimum": 0,
          "type": "integer"
        },
        "indiana-param": {
          "maximum": 255,
          "minimum": 0,
          "type": "integer"
        },
        "message-id": {
          "maximum": 65535,
          "minimum": 0,
          "type": "integer"
        },
        "oid": {
          "type": "string"
        },
        "oid-value": {
          "type": "string"
        },
        "register": {
          "type": "string"
        },
        "register-value": {
          "type": "string"
        }
      },
      "required": [
        "decoder"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "approach": {
      "type": "string"
    },
    "channel": {
      "maximum": 4294967295,
      "minimum": 0,
      "type": "integer"
    },
    "kind": {
      "type": "string"
    },
    "lane": {
      "type": "string"
    },
    "occurred-at": {
      "format": "date-time",
      "type": "string"
    },
    "phase-served": {
      "maximum": 255,
      "minimum": 0,
      "type": "integer"
    },
    "source": {
      "$ref": "#/$defs/WireSource"
    },
    "source-device-id": {
      "maxLength": 64,
      "minLength": 1,
      "pattern": "^([a-zA-Z0-9_-]+)$",
      "type": "string"
    },
    "transition": {
      "enum": [
        "fault-excessive-change",
        "fault-open-loop",
        "fault-other",
        "fault-shorted-loop",
        "fault-watchdog",
        "off",
        "on",
        "restored",
        "unspecified"
      ],
      "type": "string"
    }
  },
  "required": [
    "channel",
    "kind",
    "occurred-at",
    "source-device-id"
  ],
  "type": "object"
}
}
