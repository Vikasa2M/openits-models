{
  "lockout-denied": {
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "current-holder": {
      "type": "string"
    },
    "held-priority": {
      "maximum": 255,
      "minimum": 1,
      "type": "integer"
    },
    "kind": {
      "type": "string"
    },
    "observed-by": {
      "maxLength": 64,
      "minLength": 1,
      "pattern": "^([a-zA-Z0-9_-]+)$",
      "type": "string"
    },
    "occurred-at": {
      "format": "date-time",
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "requested-by": {
      "type": "string"
    },
    "requested-priority": {
      "maximum": 255,
      "minimum": 1,
      "type": "integer"
    },
    "sequence": {
      "type": "string"
    },
    "source-device-id": {
      "maxLength": 64,
      "minLength": 1,
      "pattern": "^([a-zA-Z0-9_-]+)$",
      "type": "string"
    }
  },
  "required": [
    "kind",
    "occurred-at",
    "requested-by",
    "sequence",
    "source-device-id"
  ],
  "type": "object"
},
  "ptz-preset-recalled": {
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "kind": {
      "type": "string"
    },
    "observed-by": {
      "maxLength": 64,
      "minLength": 1,
      "pattern": "^([a-zA-Z0-9_-]+)$",
      "type": "string"
    },
    "occurred-at": {
      "format": "date-time",
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "preset-id": {
      "maximum": 65535,
      "minimum": 0,
      "type": "integer"
    },
    "preset-name": {
      "type": "string"
    },
    "recalled-by": {
      "type": "string"
    },
    "sequence": {
      "type": "string"
    },
    "source-device-id": {
      "maxLength": 64,
      "minLength": 1,
      "pattern": "^([a-zA-Z0-9_-]+)$",
      "type": "string"
    },
    "via-tour": {
      "type": "boolean"
    }
  },
  "required": [
    "kind",
    "occurred-at",
    "preset-id",
    "sequence",
    "source-device-id"
  ],
  "type": "object"
},
  "tour-state-changed": {
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "current-state": {
      "enum": [
        "paused",
        "running",
        "stopped"
      ],
      "type": "string"
    },
    "kind": {
      "type": "string"
    },
    "observed-by": {
      "maxLength": 64,
      "minLength": 1,
      "pattern": "^([a-zA-Z0-9_-]+)$",
      "type": "string"
    },
    "occurred-at": {
      "format": "date-time",
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "previous-state": {
      "enum": [
        "paused",
        "running",
        "stopped"
      ],
      "type": "string"
    },
    "sequence": {
      "type": "string"
    },
    "source-device-id": {
      "maxLength": 64,
      "minLength": 1,
      "pattern": "^([a-zA-Z0-9_-]+)$",
      "type": "string"
    },
    "tour-id": {
      "maximum": 65535,
      "minimum": 0,
      "type": "integer"
    }
  },
  "required": [
    "current-state",
    "kind",
    "occurred-at",
    "sequence",
    "source-device-id",
    "tour-id"
  ],
  "type": "object"
}
}
