{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "from-direction": {
      "enum": [
        "eastbound",
        "northbound",
        "southbound",
        "unknown",
        "westbound"
      ],
      "type": "string"
    },
    "kind": {
      "type": "string"
    },
    "observed-by": {
      "maxLength": 64,
      "minLength": 1,
      "pattern": "^([a-zA-Z0-9_-]+)$",
      "type": "string"
    },
    "occurred-at": {
      "format": "date-time",
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "sequence": {
      "type": "string"
    },
    "sequence-step": {
      "type": "string"
    },
    "source-device-id": {
      "maxLength": 64,
      "minLength": 1,
      "pattern": "^([a-zA-Z0-9_-]+)$",
      "type": "string"
    },
    "started-at": {
      "format": "date-time",
      "type": "string"
    },
    "timeout-s": {
      "maximum": 65535,
      "minimum": 0,
      "type": "integer"
    },
    "to-direction": {
      "enum": [
        "eastbound",
        "northbound",
        "southbound",
        "unknown",
        "westbound"
      ],
      "type": "string"
    }
  },
  "required": [
    "kind",
    "occurred-at",
    "sequence",
    "source-device-id"
  ],
  "type": "object"
}