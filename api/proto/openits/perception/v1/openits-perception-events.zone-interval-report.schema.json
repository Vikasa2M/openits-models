{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "kind": {
      "type": "string"
    },
    "observed-by": {
      "maxLength": 64,
      "minLength": 1,
      "pattern": "^([a-zA-Z0-9_-]+)$",
      "type": "string"
    },
    "occurred-at": {
      "format": "date-time",
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "sequence": {
      "type": "string"
    },
    "source-device-id": {
      "maxLength": 64,
      "minLength": 1,
      "pattern": "^([a-zA-Z0-9_-]+)$",
      "type": "string"
    },
    "zone": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "average-speed-kmh": {
            "type": "string"
          },
          "class-count": {
            "items": {
              "additionalProperties": false,
              "properties": {
                "class": {
                  "type": "string"
                },
                "count": {
                  "maximum": 4294967295,
                  "minimum": 0,
                  "type": "integer"
                }
              },
              "type": "object"
            },
            "type": "array"
          },
          "crossed-volume": {
            "maximum": 4294967295,
            "minimum": 0,
            "type": "integer"
          },
          "interval-duration-s": {
            "maximum": 3600,
            "minimum": 1,
            "type": "integer"
          },
          "interval-start": {
            "format": "date-time",
            "type": "string"
          },
          "observed-count": {
            "maximum": 4294967295,
            "minimum": 0,
            "type": "integer"
          },
          "occupancy-percent": {
            "type": "string"
          },
          "zone-id": {
            "maxLength": 64,
            "minLength": 1,
            "pattern": "^([a-zA-Z0-9_-]+)$",
            "type": "string"
          }
        },
        "type": "object"
      },
      "type": "array"
    }
  },
  "required": [
    "kind",
    "occurred-at",
    "sequence",
    "source-device-id"
  ],
  "type": "object"
}