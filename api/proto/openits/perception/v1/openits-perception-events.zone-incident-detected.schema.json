{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "confidence": {
      "maximum": 100,
      "minimum": 0,
      "type": "integer"
    },
    "incident-id": {
      "type": "string"
    },
    "kind": {
      "type": "string"
    },
    "latitude": {
      "type": "string"
    },
    "longitude": {
      "type": "string"
    },
    "object-class": {
      "type": "string"
    },
    "observed-by": {
      "maxLength": 64,
      "minLength": 1,
      "pattern": "^([a-zA-Z0-9_-]+)$",
      "type": "string"
    },
    "occurred-at": {
      "format": "date-time",
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "sequence": {
      "type": "string"
    },
    "severity": {
      "enum": [
        "intermediate",
        "major",
        "minor"
      ],
      "type": "string"
    },
    "source-device-id": {
      "maxLength": 64,
      "minLength": 1,
      "pattern": "^([a-zA-Z0-9_-]+)$",
      "type": "string"
    },
    "speed-kmh": {
      "type": "string"
    },
    "track-epoch": {
      "maximum": 4294967295,
      "minimum": 0,
      "type": "integer"
    },
    "track-id": {
      "maximum": 4294967295,
      "minimum": 0,
      "type": "integer"
    },
    "type": {
      "type": "string"
    },
    "zone-id": {
      "maxLength": 64,
      "minLength": 1,
      "pattern": "^([a-zA-Z0-9_-]+)$",
      "type": "string"
    }
  },
  "required": [
    "kind",
    "occurred-at",
    "sequence",
    "source-device-id"
  ],
  "type": "object"
}