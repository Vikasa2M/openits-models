{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "decision-authority": {
      "enum": [
        "controller-prs",
        "evp-auto",
        "none",
        "operator",
        "rsu-local"
      ],
      "type": "string"
    },
    "kind": {
      "type": "string"
    },
    "new-status": {
      "enum": [
        "active",
        "approved",
        "completed",
        "denied",
        "pending"
      ],
      "type": "string"
    },
    "observed-by": {
      "maxLength": 64,
      "minLength": 1,
      "pattern": "^([a-zA-Z0-9_-]+)$",
      "type": "string"
    },
    "occurred-at": {
      "format": "date-time",
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "previous-status": {
      "enum": [
        "active",
        "approved",
        "completed",
        "denied",
        "pending"
      ],
      "type": "string"
    },
    "request-id": {
      "type": "string"
    },
    "sequence": {
      "type": "string"
    },
    "source-device-id": {
      "maxLength": 64,
      "minLength": 1,
      "pattern": "^([a-zA-Z0-9_-]+)$",
      "type": "string"
    },
    "vehicle-id": {
      "type": "string"
    }
  },
  "required": [
    "kind",
    "occurred-at",
    "sequence",
    "source-device-id"
  ],
  "type": "object"
}