{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "channel-id": {
      "type": "string"
    },
    "dsrc-channel-number": {
      "maximum": 184,
      "minimum": 172,
      "type": "integer"
    },
    "fault-type": {
      "type": "string"
    },
    "kind": {
      "type": "string"
    },
    "message": {
      "type": "string"
    },
    "observed-by": {
      "maxLength": 64,
      "minLength": 1,
      "pattern": "^([a-zA-Z0-9_-]+)$",
      "type": "string"
    },
    "occurred-at": {
      "format": "date-time",
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "sequence": {
      "type": "string"
    },
    "source-device-id": {
      "maxLength": 64,
      "minLength": 1,
      "pattern": "^([a-zA-Z0-9_-]+)$",
      "type": "string"
    }
  },
  "required": [
    "kind",
    "occurred-at",
    "sequence",
    "source-device-id"
  ],
  "type": "object"
}