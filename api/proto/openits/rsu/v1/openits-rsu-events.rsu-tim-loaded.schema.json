{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "content-summary": {
      "type": "string"
    },
    "duration-seconds": {
      "maximum": 4294967295,
      "minimum": 0,
      "type": "integer"
    },
    "kind": {
      "type": "string"
    },
    "msg-id": {
      "type": "string"
    },
    "observed-by": {
      "maxLength": 64,
      "minLength": 1,
      "pattern": "^([a-zA-Z0-9_-]+)$",
      "type": "string"
    },
    "occurred-at": {
      "format": "date-time",
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "priority": {
      "maximum": 7,
      "minimum": 0,
      "type": "integer"
    },
    "sequence": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "source-device-id": {
      "maxLength": 64,
      "minLength": 1,
      "pattern": "^([a-zA-Z0-9_-]+)$",
      "type": "string"
    },
    "start-time": {
      "format": "date-time",
      "type": "string"
    }
  },
  "required": [
    "kind",
    "msg-id",
    "occurred-at",
    "sequence",
    "source-device-id"
  ],
  "type": "object"
}