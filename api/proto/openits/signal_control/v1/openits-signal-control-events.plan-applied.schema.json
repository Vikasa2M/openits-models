{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "cycle-length-s": {
      "maximum": 65535,
      "minimum": 0,
      "type": "integer"
    },
    "kind": {
      "type": "string"
    },
    "observed-by": {
      "maxLength": 64,
      "minLength": 1,
      "pattern": "^([a-zA-Z0-9_-]+)$",
      "type": "string"
    },
    "occurred-at": {
      "format": "date-time",
      "type": "string"
    },
    "offset-s": {
      "maximum": 65535,
      "minimum": 0,
      "type": "integer"
    },
    "owner": {
      "type": "string"
    },
    "plan-id": {
      "maximum": 255,
      "minimum": 1,
      "type": "integer"
    },
    "sequence": {
      "type": "string"
    },
    "source": {
      "enum": [
        "adaptive",
        "operator",
        "preemption",
        "schedule",
        "unspecified"
      ],
      "type": "string"
    },
    "source-device-id": {
      "maxLength": 64,
      "minLength": 1,
      "pattern": "^([a-zA-Z0-9_-]+)$",
      "type": "string"
    },
    "split-set": {
      "maximum": 255,
      "minimum": 0,
      "type": "integer"
    }
  },
  "required": [
    "kind",
    "occurred-at",
    "sequence",
    "source-device-id"
  ],
  "type": "object"
}